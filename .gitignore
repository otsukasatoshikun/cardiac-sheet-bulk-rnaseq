# =============================================================================
# .gitignore for the GitHub-public copy of revision_20260617/scripts/
# Strategy: keep B-level (2026-06-06) production scripts 01-09 + config/ only.
# Local development artifacts, prior versions, trial variants, intermediate
# outputs, raw input data, and run logs are excluded from the public repo.
# =============================================================================

# ---- Internal-only verification script (requires legacy v1 intermediates) ----
# 09 compares the new v2 pipeline output against legacy v1 outputs that are NOT
# included in this repository, so it cannot run from a fresh clone. Kept locally
# for the authors' internal reproducibility audit only.
09_verify_consistency.py

# ---- Prior versions (kept locally per project no-delete rule) ----
08_fig1h_hclust_v1_20260606.py
07_fig1g_ion_channels_v1_legendOutside_20260608.py

# Generic pattern for future prior-version backups (file_vN_*_YYYYMMDD.py)
*_v[0-9]_*_2026[0-9][0-9][0-9][0-9].py

# ---- Fig 1H drawing-variant trials (kept locally as exploration record) ----
08a_fig1h_hclust_variant_a.py
08b_fig1h_hclust_variant_b.py
08c_fig1h_hclust_variant_c.py
08c2_fig1h_hclust_variant_c2.py
08c3_fig1h_hclust_variant_c3.py
08c4_fig1h_hclust_variant_c4.py
08c5_fig1h_hclust_variant_c5.py
08c6_fig1h_hclust_variant_c6.py

# Output PNGs from the variant trials (kept locally)
../figures/v2_rerun/fig1h_variant_*.png

# Prior-version backup PNGs (e.g. fig1g_v1_legendOutside_20260608.png)
../figures/v2_rerun/*_v[0-9]_*_2026[0-9][0-9][0-9][0-9].png

# ---- One-off diagnostic helpers (not part of the pipeline) ----
_inspect_h5ad.py

# ---- Intermediate / generated outputs (regenerated by running 01-09) ----
intermediate/
verification_report*.md
../figures/v2_rerun/fig1e.png
../figures/v2_rerun/fig1f.png
../figures/v2_rerun/fig1g.png
../figures/v2_rerun/fig1h.png

# ---- Raw input data (must be downloaded from GEO / heartcellatlas.org) ----
../../../data/
data/

# ---- Run logs ----
../../../logs/_run_*.log
*.log

# =============================================================================
# Standard Python ignores
# =============================================================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter Notebook
.ipynb_checkpoints/

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
desktop.ini

# Secrets / local config (none expected here, but defensive)
.env
.env.local
*.pem
*.key
